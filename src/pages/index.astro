---
// src/pages/index.astro
import '../styles/global.css';
---

<html lang="es">
<head>
	<meta charset="UTF-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1.0" />
	<title>Advanced Team Elite ®</title>

	<link rel="preconnect" href="https://fonts.googleapis.com" />
	<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
	<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet" />
</head>

<body class="no-scroll">
<div id="grain"></div>
<canvas id="fluid"></canvas>

<div id="preloader">
	<div class="pre-logo">ATE</div>
	<div class="pre-bar-outer"><div class="pre-bar" id="pre-bar"></div></div>
	<div class="pre-count" id="pre-count">0%</div>
</div>

<header>
	<a class="logo" href="#">Advanced Team Elite </a>
	<nav class="desktop-nav">
		<a href="#about">Agency</a>
		<a href="#services">Services</a>
		<a href="#contact">Contact</a>
	</nav>
</header>

<div id="container-3d"></div>

<section class="scene-trigger">
	<section class="hero" id="hero">
		<h1 class="hero-title">
			<span class="line"><span>Advanced</span></span>
			<span class="line"><span>Team</span></span>
			<span class="line"><span>Elite</span></span>
			<span class="line"><span>Group</span></span>
		</h1>
		<p class="hero-desc">
			ATE is the parent company behind high-performance service divisions
			delivering construction, roofing, plumbing and technical solutions
			with elite execution standards.
		</p>
		<div class="scroll-hint">Explore Divisions</div>
	</section>
</section>


<div class="marquee-section">
	<div class="marquee-track">
		<span class="marquee-item">Construction</span>
		<span class="marquee-item accent"> — </span>
		<span class="marquee-item">Roofing</span>
		<span class="marquee-item accent"> — </span>
		<span class="marquee-item">Plumbing</span>
		<span class="marquee-item accent"> — </span>
		<span class="marquee-item">Electrical</span>
		<span class="marquee-item accent"> — </span>
		<span class="marquee-item">Elite Service</span>
	</div>
</div>

<section class="about" id="about">
	<div class="about-left">
		<p class="about-label">About ATE</p>
		<h2 class="about-heading" id="about-heading">
			<span class="word"><span>One</span></span>
			<span class="word"><span> parent</span></span><br />
			<span class="word"><span>company.</span></span><br />
			<span class="word"><span>Multiple</span></span>
			<span class="word"><span> elite</span></span><br />
			<span class="word"><span>divisions.</span></span>
		</h2>
	</div>
	<div class="about-text">
		<p>
			Advanced Team Elite (ATE) operates as a holding and strategic management group
			overseeing specialized service brands across the construction industry.
		</p>
		<p>
			Each division operates independently in the field while maintaining unified
			standards of performance, safety and operational excellence.
		</p>
		<div class="about-stat">
			<div class="stat-num" data-count="5">0</div>
			<div class="stat-label">Divisions</div>

			<div class="stat-num" data-count="250">0</div>
			<div class="stat-label">Projects</div>

			<div class="stat-num" data-count="12">0</div>
			<div class="stat-label">Years</div>
		</div>
	</div>
</section>

<section class="services" id="services">
	<div class="services-header">
		<span class="section-label">Our Structure</span>
		<span class="section-label">(05 divisions)</span>
	</div>
	<ul class="services-list">
		<li class="service-item">
			<div class="service-inner">
				<span class="service-name">Advanced Construction Team</span>
				<span class="service-num">01</span>
			</div>
		</li>

		<li class="service-item">
			<div class="service-inner">
				<span class="service-name">Advanced Roofing</span>
				<span class="service-num">02</span>
			</div>
		</li>

		<li class="service-item">
			<div class="service-inner">
				<span class="service-name">Advanced Plumbing</span>
				<span class="service-num">03</span>
			</div>
		</li>

		<li class="service-item">
			<div class="service-inner">
				<span class="service-name">Advanced Electrical</span>
				<span class="service-num">04</span>
			</div>
		</li>

		<li class="service-item">
			<div class="service-inner">
				<span class="service-name">Advanced Project Management</span>
				<span class="service-num">05</span>
			</div>
		</li>
	</ul>
</section>

<section class="contact" id="contact">
	<p class="contact-pre">Work With The Elite</p>
	<h2 class="contact-heading">
		<span class="line"><span>Partner</span></span>
		<span class="line"><span>With ATE</span></span>
	</h2>

	<a href="mailto:info@advancedteamelite.com" class="contact-cta">
		<span>info@advancedteamelite.com</span>
	</a>
</section>

<footer>
	<p>© 2025 Advanced Team Elite ®</p>
	<p>Holding & Strategic Management Group</p>
	<p>United States</p>
</footer>

<script>
	// Importamos las librerías base y el nuevo fluido
	import { initLenis } from '../scripts/lenis.js';
	import { initPreloader, initScrollAnimations } from '../scripts/animations.js';
	import { initFluid } from '../scripts/fluid.js';
	import { initScene3D } from '../scripts/scene3d.js'; // Importar nueva escena

	// Ejecución
	initLenis();
	initPreloader();
	initScrollAnimations();

	// El fluido profesional se inicializa solo
	initFluid();
	initScene3D();
</script>

<!-- En lugar del <script is:inline src="..."> anterior -->
<script is:inline>
	(function() {
		const WIDGET_URL  = "https://roofing-quote-two.vercel.app/widget";
		const ACCENT      = "#1d4ed8";
		const BTN_LABEL   = "Free Roof Quote";
		const POSITION    = "right";

		const css = `
        #rq-launcher {
            position: fixed;
            bottom: 24px;
            right: 24px;
            z-index: 99999;
            display: flex;
            flex-direction: column;
            align-items: flex-end;
            gap: 12px;
            font-family: system-ui, sans-serif;
        }
        #rq-panel {
            width: 420px;
            max-width: calc(100vw - 32px);
            height: 640px;
            max-height: calc(100vh - 100px);
            border: none;
            border-radius: 16px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.18);
            transition: opacity 0.2s ease, transform 0.2s ease;
            background: white;
        }
        #rq-panel.rq-hidden {
            opacity: 0;
            pointer-events: none;
            transform: translateY(12px);
        }
        #rq-btn {
            background: ${ACCENT};
            color: white;
            border: none;
            border-radius: 999px;
            padding: 14px 22px;
            font-size: 15px;
            font-weight: 700;
            cursor: pointer;
            box-shadow: 0 4px 20px rgba(0,0,0,0.2);
            display: flex;
            align-items: center;
            gap: 8px;
            transition: transform 0.15s ease, box-shadow 0.15s ease;
        }
        #rq-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 24px rgba(0,0,0,0.25);
        }
    `;

		const style = document.createElement("style");
		style.textContent = css;
		document.head.appendChild(style);

		const launcher = document.createElement("div");
		launcher.id = "rq-launcher";

		const iframe = document.createElement("iframe");
		iframe.id  = "rq-panel";
		iframe.src = WIDGET_URL;
		iframe.classList.add("rq-hidden");
		iframe.setAttribute("title", "Roofing Quote Widget");

		const btn = document.createElement("button");
		btn.id = "rq-btn";
		btn.innerHTML = `
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M3 9.5L12 3l9 6.5V20a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V9.5z"/>
            <polyline points="9 21 9 12 15 12 15 21"/>
        </svg>
        <span>Free Roof Quote</span>
    `;

		launcher.appendChild(iframe);
		launcher.appendChild(btn);
		document.body.appendChild(launcher);

		let isOpen = false;
		btn.addEventListener("click", () => {
			isOpen = !isOpen;
			iframe.classList.toggle("rq-hidden", !isOpen);
			btn.querySelector("span").textContent = isOpen ? "Close" : BTN_LABEL;
		});

		document.addEventListener("click", (e) => {
			if (isOpen && !launcher.contains(e.target)) {
				isOpen = false;
				iframe.classList.add("rq-hidden");
				btn.querySelector("span").textContent = BTN_LABEL;
			}
		});
	})();
</script>

</body>
</html>