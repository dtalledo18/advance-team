---
// src/pages/index.astro
import '../styles/global.css';
---

<html lang="es">
<head>
	<meta charset="UTF-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1.0" />
	<title>Advanced Team ®</title>

	<link rel="preconnect" href="https://fonts.googleapis.com" />
	<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
	<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet" />
</head>

<body class="no-scroll">
<div id="grain"></div>
<canvas id="fluid"></canvas>

<div id="preloader">
	<div class="pre-logo">ATE</div>
	<div class="pre-bar-outer"><div class="pre-bar" id="pre-bar"></div></div>
	<div class="pre-count" id="pre-count">0%</div>
</div>

<header>
	<a class="logo" href="#">Advanced Team </a>
	<nav class="desktop-nav">
		<a href="#about">Agency</a>
		<a href="#services">Services</a>
		<a href="#contact">Contact</a>
	</nav>
</header>

<div id="container-3d"></div>

<section class="scene-trigger">
	<section class="hero" id="hero">
		<h1 class="hero-title">
			<span class="line"><span>Advanced</span></span>
			<span class="line"><span>Team</span></span>
			<span class="line"><span>Group</span></span>
		</h1>
		<p class="hero-desc">
			ATE is the parent company behind high-performance service divisions
			delivering construction, roofing, plumbing and technical solutions
			with elite execution standards.
		</p>
		<div class="scroll-hint">Explore Divisions</div>
	</section>
</section>


<div class="marquee-section">
	<div class="marquee-track">
		<span class="marquee-item">Construction</span>
		<span class="marquee-item accent"> — </span>
		<span class="marquee-item">Roofing</span>
		<span class="marquee-item accent"> — </span>
		<span class="marquee-item">Plumbing</span>
		<span class="marquee-item accent"> — </span>
		<span class="marquee-item">Management</span>
		<span class="marquee-item accent"> — </span>
		<span class="marquee-item">Service</span>
	</div>
</div>

<section class="about" id="about">
	<div class="about-left">
		<p class="about-label">About AT</p>
		<h2 class="about-heading" id="about-heading">
			<span class="word"><span>One</span></span>
			<span class="word"><span> parent</span></span><br />
			<span class="word"><span>company.</span></span><br />
			<span class="word"><span>Multiple</span></span>
			<span class="word"><span> elite</span></span><br />
			<span class="word"><span>divisions.</span></span>
		</h2>
	</div>
	<div class="about-text">
		<p>
			Advanced Team operates as a holding and strategic management group
			overseeing specialized service brands across the construction industry.
		</p>
		<p>
			Each division operates independently in the field while maintaining unified
			standards of performance, safety and operational excellence.
		</p>
		<div class="about-stat">
			<div class="stat-num" data-count="5">0</div>
			<div class="stat-label">Divisions</div>

			<div class="stat-num" data-count="250">0</div>
			<div class="stat-label">Projects</div>

			<div class="stat-num" data-count="12">0</div>
			<div class="stat-label">Years</div>
		</div>
	</div>
</section>

<section class="services" id="services">
	<div class="services-header">
		<span class="section-label">Our Structure</span>
		<span class="section-label">(05 divisions)</span>
	</div>
	<ul class="services-list">
		<li class="service-item">
			<div class="service-inner">
				<span class="service-name">Advanced Construction Team</span>
				<span class="service-num">01</span>
			</div>
		</li>

		<li class="service-item">
			<div class="service-inner">
				<span class="service-name">Advanced Roofing</span>
				<span class="service-num">02</span>
			</div>
		</li>

		<li class="service-item">
			<div class="service-inner">
				<span class="service-name">Advanced Plumbing</span>
				<span class="service-num">03</span>
			</div>
		</li>

		<li class="service-item">
			<div class="service-inner">
				<span class="service-name">Advanced Electrical</span>
				<span class="service-num">04</span>
			</div>
		</li>

		<li class="service-item">
			<div class="service-inner">
				<span class="service-name">Advanced Project Management</span>
				<span class="service-num">05</span>
			</div>
		</li>
	</ul>
</section>

<section class="contact" id="contact">
	<p class="contact-pre">Work With The Advanced</p>
	<h2 class="contact-heading">
		<span class="line"><span>Partner</span></span>
		<span class="line"><span>With AT</span></span>
	</h2>

	<a href="mailto:info@advancedteam.com" class="contact-cta">
		<span>info@advancedteam.com</span>
	</a>
</section>

<footer>
	<p>© 2025 Advanced Team ®</p>
	<p>Holding & Strategic Management Group</p>
	<p>United States</p>
</footer>

<script>
	// Importamos las librerías base y el nuevo fluido
	import { initLenis } from '../scripts/lenis.js';
	import { initPreloader, initScrollAnimations } from '../scripts/animations.js';
	import { initFluid } from '../scripts/fluid.js';
	import { initScene3D } from '../scripts/scene3d.js'; // Importar nueva escena

	// Ejecución
	initLenis();
	initPreloader();
	initScrollAnimations();

	// El fluido profesional se inicializa solo
	initFluid();
	initScene3D();
</script>

<script is:inline>
	(function() {
		const WIDGET_URL = "https://roofing-quote-two.vercel.app/widget";
		const ACCENT     = "#1d4ed8";
		const LABEL      = "Free Roof Quote";

		const css = `
        #rq-tab {
            position: fixed;
            right: 0;
            top: 50%;
            transform: translateY(-50%);
            z-index: 99998;
            background: ${ACCENT};
            color: white;
            writing-mode: vertical-rl;
            text-orientation: mixed;
            transform: translateY(-50%) rotate(180deg);
            padding: 20px 10px;
            border-radius: 0 8px 8px 0;
            font-family: system-ui, sans-serif;
            font-size: 13px;
            font-weight: 800;
            letter-spacing: 0.1em;
            text-transform: uppercase;
            cursor: pointer;
            border: none;
            box-shadow: -4px 0 20px rgba(0,0,0,0.2);
            display: flex;
            align-items: center;
            gap: 10px;
            transition: padding 0.2s ease, box-shadow 0.2s ease;
            user-select: none;
        }
        #rq-tab:hover {
            padding: 20px 14px;
            box-shadow: -6px 0 28px rgba(0,0,0,0.28);
        }
        #rq-tab svg {
            transform: rotate(90deg);
            flex-shrink: 0;
        }

        #rq-tab::before { top: 10px; }
        #rq-tab::after  { bottom: 10px; }

        /* Overlay */
        #rq-overlay {
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,0.4);
            z-index: 99998;
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.3s ease;
            backdrop-filter: blur(2px);
        }
        #rq-overlay.rq-open {
            opacity: 1;
            pointer-events: all;
        }

        /* Panel lateral */
        #rq-panel-wrap {
            position: fixed;
            top: 0;
            right: 0;
            height: 100%;
            width: 660px;
            max-width: 100vw;
            z-index: 99999;
            transform: translateX(100%);
            transition: transform 0.35s cubic-bezier(0.32, 0.72, 0, 1);
            display: flex;
            flex-direction: column;
            background: white;
            box-shadow: -8px 0 40px rgba(0,0,0,0.18);
        }
        #rq-panel-wrap.rq-open {
            transform: translateX(0);
        }

        /* Handle superior del panel */
        #rq-panel-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 16px 20px;
            background: ${ACCENT};
            color: white;
            font-family: system-ui, sans-serif;
            flex-shrink: 0;
        }
        #rq-panel-header span {
            font-size: 15px;
            font-weight: 800;
            letter-spacing: 0.05em;
            text-transform: uppercase;
        }
        #rq-close-btn {
            background: rgba(255,255,255,0.2);
            border: none;
            color: white;
            width: 32px;
            height: 32px;
            border-radius: 50%;
            cursor: pointer;
            font-size: 18px;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: background 0.15s;
            line-height: 1;
        }
        #rq-close-btn:hover {
            background: rgba(255,255,255,0.35);
        }

        #rq-iframe {
            flex: 1;
            border: none;
            width: 100%;
        }
    `;

		const style = document.createElement("style");
		style.textContent = css;
		document.head.appendChild(style);

		// ── Tab (etiqueta) ──────────────────────────────────────────
		const tab = document.createElement("button");
		tab.id = "rq-tab";
		tab.innerHTML = `
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2.5"
             stroke-linecap="round" stroke-linejoin="round">
            <path d="M3 9.5L12 3l9 6.5V20a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V9.5z"/>
            <polyline points="9 21 9 12 15 12 15 21"/>
        </svg>
        ${LABEL}
    `;

		// ── Overlay ─────────────────────────────────────────────────
		const overlay = document.createElement("div");
		overlay.id = "rq-overlay";

		// ── Panel ───────────────────────────────────────────────────
		const panelWrap = document.createElement("div");
		panelWrap.id = "rq-panel-wrap";

		const panelHeader = document.createElement("div");
		panelHeader.id = "rq-panel-header";
		panelHeader.innerHTML = `
        <span>${LABEL}</span>
        <button id="rq-close-btn" aria-label="Close">✕</button>
    `;

		const iframe = document.createElement("iframe");
		iframe.id  = "rq-iframe";
		iframe.src = WIDGET_URL;
		iframe.setAttribute("title", "Roofing Quote");

		panelWrap.appendChild(panelHeader);
		panelWrap.appendChild(iframe);

		document.body.appendChild(overlay);
		document.body.appendChild(panelWrap);
		document.body.appendChild(tab);

		// ── Lógica ──────────────────────────────────────────────────
		let isOpen = false;

		function open() {
			isOpen = true;
			panelWrap.classList.add("rq-open");
			overlay.classList.add("rq-open");
			tab.style.opacity = "0";
			tab.style.pointerEvents = "none";
		}

		function close() {
			isOpen = false;
			panelWrap.classList.remove("rq-open");
			overlay.classList.remove("rq-open");
			tab.style.opacity = "1";
			tab.style.pointerEvents = "auto";
		}

		tab.addEventListener("click", open);
		overlay.addEventListener("click", close);
		document.getElementById("rq-panel-header")
			.querySelector("#rq-close-btn")
			.addEventListener("click", close);

		// Cerrar con Escape
		document.addEventListener("keydown", (e) => {
			if (e.key === "Escape" && isOpen) close();
		});
	})();
</script>

</body>
</html>